# Copie para .env e preencha. NÃO comitar o .env real.

# Admin inicial (bootstrap): criado no 1º startup se não houver nenhum usuário.
# Depois disso, usuários e senhas vivem no banco (hash bcrypt) — estas chaves só
# fazem o primeiro admin existir. Troque a senha do admin após o 1º login.
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha-do-admin

# Chave para assinar a sessão/JWT (gere uma aleatória longa)
SECRET_KEY=gere-uma-chave-aleatoria-bem-longa

# Caminho do banco SQLite (financeiro + agenda)
DB_PATH=./painel.db

# Pasta para snapshots do comparador de seguidores (arquivos .json, sem banco)
SNAPSHOT_DIR=./snapshots

# Minutos de validade do token de sessão
ACCESS_TOKEN_EXPIRE_MINUTES=10080
